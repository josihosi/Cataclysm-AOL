{
  "name": "chat.nearby_npc_basic",
  "description": "Launch the harness-owned McWilliams basecamp fixture, exercise the current nearby-NPC/freeform chat path, and capture screen plus llm_intent artifacts separately.",
  "profile": "dev-harness",
  "world": "McWilliams",
  "profile_snapshot": "mcwilliams_live_debug_2026-04-07",
  "profile_snapshot_profile": "live-debug",
  "fixture": "mcwilliams_live_debug_2026-04-07",
  "fixture_profile": "live-debug",
  "replace_existing_worlds": true,
