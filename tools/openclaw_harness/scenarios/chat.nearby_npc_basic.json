    {
      "kind": "type",
      "label": "send_chat_utterance",
      "text": "Hello there.",
      "submit": true,
      "settle_seconds": 1.5,
      "capture_after": true
    },
    {
      "kind": "advance_turns",
      "label": "wait_for_reply",
      "count": 2,
      "settle_seconds": 1.0,
      "capture_after": true
    }
  ],
  "recommended_test_command": "./tests/cata_test \"[llm_intent]\""
}
